# ============================================
# 开发环境变量（仅 vite dev 时加载）
# ============================================

# API 基础路径 — 走 Vite proxy，避免跨域
VITE_API_BASE_URL=/api

# 代理目标地址 — 后端实际服务地址（仅开发服务器使用，不会暴露到客户端）
VITE_PROXY_TARGET=http://localhost:3000

# 是否启用 Mock 数据 — 开发服务器会拦截 /api 路径的请求，并返回 mock 数据
VITE_MOCK_ENABLED=true
